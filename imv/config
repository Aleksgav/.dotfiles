# imv image viewer config -- see `man 5 imv`
# Linked to ~/.config/imv by the arch package post_install.

[options]
# Start with a clean dark background (no ugly grid checks)
background = 000000

# Make the text overlay blend cleanly with your font configuration
overlay_font = monospace:12

# Automatically loop back to the first image when cycling folders
loop_input = true

# Fit the image to your MangoWM floating window proportions cleanly
scaling_mode = full
